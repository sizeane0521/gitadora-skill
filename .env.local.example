# Supabase 設定
# 在 Supabase Dashboard → Project Settings → API 取得
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# 歌單同步腳本專用（Supabase Dashboard → Project Settings → API → service_role key）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# 使用步驟：
# 1. 複製此檔案為 .env.local
# 2. 填入你的 Supabase 專案 URL 和 anon key
# 3. .env.local 已加入 .gitignore，不會被提交
